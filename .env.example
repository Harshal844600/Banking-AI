# Example environment variables for insight-bank-ai
# Copy to .env and fill values before running locally or in CI

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=public-anon-key
VITE_API_URL=https://api.example.com
# Feature flags
VITE_ENABLE_ANALYTICS=false

# Do NOT commit secrets to repo. Use CI secrets / hosting env vars for production.
